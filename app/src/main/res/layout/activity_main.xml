<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F3F6F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_header_gradient"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="18dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="客户通讯录管家"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Excel批量入库 · 分组管理 · 通讯录导出"
            android:textSize="13sp"
            android:textColor="#DCEFF4"
            android:paddingTop="4dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_panel"
        android:text="统计加载中..."
        android:textSize="14sp"
        android:textColor="#1F2D36"
        android:lineSpacingExtra="3dp"
        android:padding="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:background="@drawable/bg_panel"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="当前分组"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1F2D36"
                android:paddingRight="8dp" />

            <Spinner
                android:id="@+id/spGroup"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnGroupAdd"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="新建分组"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnGroupRename"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="重命名"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnGroupDelete"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="删除分组"
                    android:textSize="12sp"
                    android:textColor="#C94A4A" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginTop="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnImportExcel"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="导入Excel"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:backgroundTint="#2F6F7E" />

            <Button
                android:id="@+id/btnAdd"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="新增联系人"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnExport"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="导出CSV"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnCleanImported"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="清理已导入"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnReset"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="重置状态"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnClear"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="清空库"
                android:textSize="13sp"
                android:textColor="#C94A4A" />

            <Button
                android:id="@+id/btnHelp"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="使用说明"
                android:textSize="13sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginTop="6dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnDefaultBatch"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="默认导入20人"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:backgroundTint="#1F4E5F" />

            <Button
                android:id="@+id/btnDefaultSettings"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="默认人数"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnBatch5"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="5人"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnBatch10"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="10人"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnBatch20"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="20人"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnBatch50"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="50人"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnBatchCustom"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="自定义"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnRangeImport"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="序号区间"
                android:textSize="12sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:hint="搜索姓名 / 手机号 / 备注"
            android:singleLine="true"
            android:textSize="14sp"
            android:background="@drawable/bg_search"
            android:paddingLeft="10dp"
            android:paddingRight="10dp" />

        <Spinner
            android:id="@+id/spFilter"
            android:layout_width="130dp"
            android:layout_height="42dp" />
    </LinearLayout>

    <ListView
        android:id="@+id/listContacts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#00000000"
        android:dividerHeight="8dp"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />
</LinearLayout>
