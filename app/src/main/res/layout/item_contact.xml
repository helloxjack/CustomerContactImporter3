<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_item_card"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="姓名"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1F2D36"
            android:maxLines="2" />

        <TextView
            android:id="@+id/tvStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未导入"
            android:textSize="12sp"
            android:textColor="#2F6F7E"
            android:background="@drawable/bg_status_pending"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvPhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="手机号"
        android:textSize="14sp"
        android:textColor="#3A4A52"
        android:paddingTop="5dp" />

    <TextView
        android:id="@+id/tvInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="分组、序号、来源"
        android:textSize="12sp"
        android:textColor="#6B7A83"
        android:paddingTop="4dp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="right">

            <Button
                android:id="@+id/btnOneImport"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="导入"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2F6F7E" />

            <Button
                android:id="@+id/btnDial"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="拨号"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnSms"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="短信"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnEdit"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="编辑"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="删除"
                android:textSize="12sp"
                android:textColor="#C94A4A" />
        </LinearLayout>
    </HorizontalScrollView>
</LinearLayout>
